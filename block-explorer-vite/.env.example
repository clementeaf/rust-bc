# API backend for the dev-server proxy (must match how Cerulean Ledger is exposed).
# Plain HTTP — local: cargo run --bin rust-bc (sin TLS)
# VITE_API_PROXY_TARGET=http://127.0.0.1:8080

# HTTPS — Docker (compose mapea node1 8080, node2 8082, orderer1 8086, …). Si :8080 no responde, prueba :8082.
VITE_API_PROXY_TARGET=https://127.0.0.1:8082

# Puerto del dev server (Grafana en Docker usa 3000; por defecto 5173)
# VITE_DEV_SERVER_PORT=5173
