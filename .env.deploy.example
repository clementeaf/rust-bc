# Cerulean Ledger — Deploy Environment
# Copy to .env and fill in real values before deploying.

# Domain pointing to this server (Caddy auto-provisions TLS via Let's Encrypt)
DEPLOY_DOMAIN=cerulean.example.com

# Voto subdomain (optional, e.g. voto.cerulean.example.com)
VOTO_DOMAIN=voto.cerulean.example.com

# Node secrets (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
HMAC_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# Grafana admin password
GRAFANA_PASSWORD=CHANGE_ME_strong_password

# Build version tag (optional)
BUILD_VERSION=dev
