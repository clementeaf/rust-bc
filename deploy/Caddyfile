{$DEPLOY_DOMAIN} {
	# TLS is automatic via Let's Encrypt

	# Node API
	handle /api/* {
		reverse_proxy node:8080
	}

	# Health (public)
	handle /health {
		reverse_proxy node:8080 {
			rewrite /api/v1/health
		}
	}

	# Non-API backend endpoints
	handle /stress/* {
		reverse_proxy node:8080
	}
	handle /pentest/* {
		reverse_proxy node:8080
	}
	handle /metrics {
		reverse_proxy node:8080
	}

	# Grafana (sub-path)
	handle_path /grafana/* {
		reverse_proxy grafana:3000
	}
	handle /grafana {
		redir /grafana/ permanent
	}

	# Block Explorer — default (all other routes)
	handle {
		reverse_proxy explorer:80
	}

	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy strict-origin-when-cross-origin
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}
}

# Voto on subdomain (optional — set VOTO_DOMAIN in .env)
{$VOTO_DOMAIN:voto.localhost} {
	reverse_proxy voto:80

	handle /api/* {
		reverse_proxy node:8080
	}

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}
}
