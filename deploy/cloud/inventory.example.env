# Cloud deployment inventory
# Copy to inventory.env and fill in your VM IPs

VM1_IP=10.0.1.10
VM2_IP=10.0.1.11
VM3_IP=10.0.1.12

VM1_USER=ubuntu
VM2_USER=ubuntu
VM3_USER=ubuntu

# SSH key (optional, uses default if empty)
SSH_KEY=~/.ssh/id_rsa

# Network
NETWORK_ID=prod-net
SIGNING_ALGORITHM=ed25519
